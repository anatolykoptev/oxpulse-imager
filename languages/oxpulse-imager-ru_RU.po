msgstr "Прогрето:"

#: src/admin/sections/PrewarmSection.jsx:118
msgid "Skipped:"
msgstr "Пропущено:"

#: src/admin/sections/PrewarmSection.jsx:121
msgid "Failed:"
msgstr "Неудачно:"

#: src/admin/sections/PrewarmSection.jsx:128
msgid "Per-URL results"
msgstr "Результаты по URL"

#: src/admin/sections/FormatSection.jsx:43
msgid "Output format"
msgstr "Формат вывода"

#: src/admin/sections/FormatSection.jsx:46
msgid "Default output format"
msgstr "Формат вывода по умолчанию"

#: src/admin/sections/FormatSection.jsx:50
msgid "auto = Accept header negotiation (AVIF/WebP/original based on browser support, requires IMGPROXY_AUTO_AVIF on the server). Explicit format overrides negotiation."
msgstr "auto = негоциация через Accept (AVIF/WebP/оригинал по поддержке браузера, требует IMGPROXY_AUTO_AVIF на сервере). Явный формат переопределяет негоциацию."

#: src/admin/sections/FormatSection.jsx:56
msgid "Default quality"
msgstr "Качество по умолчанию"

#: src/admin/sections/FormatSection.jsx:57
msgid "1–100. Used when a transform request does not specify quality."
msgstr "1–100. Используется, когда transform-запрос не указывает качество."

#: src/admin/sections/FormatSection.jsx:67
msgid "AVIF quality"
msgstr "Качество AVIF"

#: src/admin/sections/FormatSection.jsx:68 src/admin/sections/FormatSection.jsx:78
msgid "use default"
msgstr "по умолчанию"

#: src/admin/sections/FormatSection.jsx:69
msgid "1–100. Overrides default for AVIF. AVIF looks good at 50-70."
msgstr "1–100. Переопределяет default для AVIF. AVIF хорошо выглядит при 50-70."

#: src/admin/sections/FormatSection.jsx:77
msgid "WebP quality"
msgstr "Качество WebP"

#: src/admin/sections/FormatSection.jsx:79
msgid "1–100. Overrides default for WebP. WebP looks good at 70-85."
msgstr "1–100. Переопределяет default для WebP. WebP хорошо выглядит при 70-85."

