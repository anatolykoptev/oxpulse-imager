#: src/admin/sections/ToolsSection.jsx:68
msgid "Health check"
msgstr "Health check"

#: src/admin/sections/ToolsSection.jsx:69
msgid "Verify that the configured imgproxy endpoint is reachable and reports healthy status."
msgstr "Проверяет, что настроенный endpoint imgproxy достижим и отвечает healthy-статусом."

#: src/admin/sections/ToolsSection.jsx:72 src/admin/sections/ToolsSection.jsx:91
msgid "Checking…"
msgstr "Проверка…"

#: src/admin/sections/ToolsSection.jsx:72 src/admin/components/OnboardingWizard.jsx:322 src/admin/components/OnboardingWizard.jsx:330
msgid "Test connection"
msgstr "Проверить подключение"

#: src/admin/sections/ToolsSection.jsx:78
msgid "AVIF format check"
msgstr "Проверка формата AVIF"

#: src/admin/sections/ToolsSection.jsx:79
msgid "Verify that imgproxy is configured for AVIF format negotiation (IMGPROXY_AUTO_AVIF=true). Sends a request with Accept: image/avif and checks the response Content-Type."
msgstr "Проверяет, что imgproxy настроен на AVIF-негоциацию (IMGPROXY_AUTO_AVIF=true). Отправляет запрос с Accept: image/avif и проверяет Content-Type ответа."

#: src/admin/sections/ToolsSection.jsx:84
msgid "Sample image URL"
msgstr "URL тестового изображения"

#: src/admin/sections/ToolsSection.jsx:86
msgid "A publicly accessible image URL from your allowed sources. If empty, the first allowed source + /oxpulse-avif-test.jpg is used."
msgstr "Публично доступный URL изображения из ваших allowed sources. Если пусто — используется первый allowed source + /oxpulse-avif-test.jpg."

#: src/admin/sections/ToolsSection.jsx:91 src/admin/components/OnboardingWizard.jsx:374
msgid "Test AVIF support"
msgstr "Проверить поддержку AVIF"

#: src/admin/sections/PrewarmSection.jsx:32
msgid "Enter at least one URL."
msgstr "Введите хотя бы один URL."

#: src/admin/sections/PrewarmSection.jsx:37
msgid "Maximum 50 URLs per batch."
msgstr "Максимум 50 URL на батч."

#: src/admin/sections/PrewarmSection.jsx:54
msgid "Pre-warm failed."
msgstr "Прогрев не удался."

#: src/admin/sections/PrewarmSection.jsx:73
msgid "Bulk pre-warm"
msgstr "Массовый прогрев"

#: src/admin/sections/PrewarmSection.jsx:74
msgid "Trigger imgproxy to process + cache a batch of source image URLs NOW, so the first visitor does not pay the processing latency. HEAD requests are dispatched with concurrency=5. Max 50 URLs per batch."
msgstr "Запускает imgproxy для обработки + кэширования батча URL изображений прямо сейчас, чтобы первый посетитель не платил за latency обработки. HEAD-запросы отправляются с concurrency=5. Максимум 50 URL на батч."

#: src/admin/sections/PrewarmSection.jsx:79
msgid "Source image URLs"
msgstr "URL исходных изображений"

#: src/admin/sections/PrewarmSection.jsx:81
msgid "One URL per line. Only URLs matching your allowed sources will be warmed."
msgstr "По одному URL на строку. Прогреваются только URL, совпадающие с allowed sources."

#: src/admin/sections/PrewarmSection.jsx:89
msgid "Target widths (optional)"
msgstr "Целевые ширины (опционально)"

#: src/admin/sections/PrewarmSection.jsx:91
msgid "Comma-separated widths in px. Empty = no resize (the default variant). Max 5 widths."
msgstr "Ширины через запятую в px. Пусто = без resize (вариант по умолчанию). Максимум 5 ширин."

#: src/admin/sections/PrewarmSection.jsx:99
msgid "Warming…"
msgstr "Прогрев…"

#: src/admin/sections/PrewarmSection.jsx:99
msgid "Warm cache"
msgstr "Прогреть кэш"

#: src/admin/sections/PrewarmSection.jsx:112
msgid "Total:"
msgstr "Всего:"

#: src/admin/sections/PrewarmSection.jsx:115
