#: src/Infrastructure/WordPress/ServiceRegistrar.php:271
msgid "Settings"
msgstr "Настройки"

#: src/Infrastructure/WordPress/SettingsValidator.php:69
msgid "Endpoint must use HTTPS in production. Enable dev HTTP override only for local development."
msgstr "Endpoint должен использовать HTTPS в production. HTTP разрешён только для локальной разработки через dev-override."

#: src/Infrastructure/WordPress/SettingsValidator.php:66
msgid "Endpoint must be HTTP or HTTPS."
msgstr "Endpoint должен быть HTTP или HTTPS."

#: src/Infrastructure/WordPress/SettingsValidator.php:62
msgid "Endpoint must be a valid URL or a relative path (e.g. /imgproxy)."
msgstr "Endpoint должен быть валидным URL или относительным путём (напр. /imgproxy)."

#: src/Infrastructure/WordPress/SettingsValidator.php:57
msgid "Relative endpoint must start with / and contain only path characters."
msgstr "Относительный endpoint должен начинаться с / и содержать только символы пути."

#. translators: %d: minimum key length in bytes.
#: src/Infrastructure/WordPress/SettingsValidator.php:84
msgid "Key must be at least %d bytes after hex decoding."
msgstr "Ключ должен быть не короче %d байт после hex-декодирования."

#: src/Infrastructure/WordPress/SettingsValidator.php:80
msgid "Key must be a non-empty even-length hexadecimal string."
msgstr "Ключ должен быть непустой hex-строкой чётной длины."

#. translators: %d: minimum salt length in bytes.
#: src/Infrastructure/WordPress/SettingsValidator.php:99
msgid "Salt must be at least %d bytes after hex decoding."
msgstr "Соль должна быть не короче %d байт после hex-декодирования."

#: src/Infrastructure/WordPress/SettingsValidator.php:95
msgid "Salt must be a non-empty even-length hexadecimal string."
msgstr "Соль должна быть непустой hex-строкой чётной длины."

#: src/Infrastructure/WordPress/SettingsValidator.php:112
msgid "Allowed sources must be valid HTTP(S) URLs with trailing path boundary."
msgstr "Allowed sources должны быть валидными HTTP(S) URL с границей пути в конце."

#. translators: 1: minimum blur, 2: maximum blur.
#: src/Infrastructure/WordPress/SettingsValidator.php:146
msgid "LQIP blur must be between %1$s and %2$s."
msgstr "Размытие LQIP должно быть между %1$s и %2$s."

#: src/Infrastructure/WordPress/SettingsValidator.php:177
msgid "Local base path is not readable by the web server."
msgstr "Local base path не доступен для чтения веб-сервером."

#: src/Infrastructure/WordPress/SettingsValidator.php:175
msgid "Local base path does not exist or is not a directory."
msgstr "Local base path не существует или не является директорией."

#: src/Infrastructure/WordPress/SettingsValidator.php:173
msgid "Local base path must be an absolute filesystem path (starting with /)."
msgstr "Local base path должен быть абсолютным путём файловой системы (начинаться с /)."

#: src/Infrastructure/WordPress/SettingsValidator.php:171
msgid "Local base path is required when source mode is \"local\"."
msgstr "Local base path обязателен, когда source mode = \"local\"."

#: src/Infrastructure/WordPress/SettingsValidator.php:191
msgid "Save-Data quality reduction must be between 0 and 50."
msgstr "Снижение качества для Save-Data должно быть от 0 до 50."

#: src/Infrastructure/WordPress/SettingsValidator.php:203
msgid "Size quality tier widths must be positive integers."
msgstr "Ширины tier-ов качества должны быть положительными целыми."

#: src/Infrastructure/WordPress/SettingsValidator.php:222
msgid "Size quality tier values must be between 1 and 100."
msgstr "Значения tier-ов качества должны быть от 1 до 100."

#: src/Infrastructure/WordPress/SettingsValidator.php:211
msgid "Size quality tier per-format values must be between 1 and 100."
msgstr "Значения tier-ов качества по форматам должны быть от 1 до 100."

#. translators: 1: format name, 2: minimum, 3: maximum.
#: src/Infrastructure/WordPress/SettingsValidator.php:328
msgid "Quality for %1$s must be between %2$d and %3$d."
msgstr "Качество для %1$s должно быть между %2$d и %3$d."

#: src/Infrastructure/WordPress/SettingsValidator.php:367
msgid "Watermark opacity must be between 0 and 1."
msgstr "Непрозрачность watermark должна быть от 0 до 1."

#: src/Infrastructure/WordPress/SettingsValidator.php:373
msgid "Invalid watermark position."
msgstr "Невалидная позиция watermark."

#: src/Infrastructure/WordPress/SettingsValidator.php:382
msgid "Watermark scale must be between 0 and 1."
msgstr "Масштаб watermark должен быть от 0 до 1."

#: src/Integration/WordPress/Admin/AdminBarDiagnostics.php:69
msgid "OXPulse Imager diagnostics — click to view details"
msgstr "Диагностика OXPulse Imager — нажмите для подробностей"

#: src/Integration/WordPress/Admin/HealthRestController.php:90, src/Integration/WordPress/Admin/HealthRestController.php:125
msgid "Endpoint URL is empty."
msgstr "URL endpoint пуст."

#: src/Integration/WordPress/Admin/HealthRestController.php:140
msgid "No sample image URL available. Configure allowed sources first."
msgstr "Нет URL тестового изображения. Сначала настройте allowed sources."

#: src/Integration/WordPress/Admin/OptionsRestController.php:151
msgid "Validation failed."
msgstr "Валидация не пройдена."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:110
msgid "No URLs provided."
msgstr "URL не переданы."

#. translators: %d: max URLs per batch
#: src/Integration/WordPress/Admin/PrewarmRestController.php:120
msgid "Too many URLs. Maximum %d per batch."
msgstr "Слишком много URL. Максимум %d на батч."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:136
msgid "No valid URLs provided."
msgstr "Нет валидных URL."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:164
msgid "Delivery is disabled. Enable it in Connection settings first."
msgstr "Delivery отключён. Сначала включите его в настройках Connection."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:172
msgid "No imgproxy endpoint configured."
msgstr "imgproxy endpoint не настроен."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:180
msgid "No signing secrets configured."
msgstr "Signing secrets не настроены."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:199
msgid "Pre-warm job created. Poll GET /oxpulse/v1/prewarm/<jobId> for progress."
msgstr "Задача pre-warm создана. Опрашивайте GET /oxpulse/v1/prewarm/<jobId> для прогресса."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:222
msgid "No job ID provided."
msgstr "Не передан ID задачи."

#: src/Integration/WordPress/Admin/PrewarmRestController.php:233
msgid "Job not found. It may have expired (jobs are kept for 1 hour)."
msgstr "Задача не найдена. Возможно, она истекла (задачи хранятся 1 час)."

#: src/Integration/WordPress/Admin/SettingsPage.php:40, src/Integration/WordPress/Admin/SettingsPage.php:41
msgid "OXPulse Imager"
msgstr "OXPulse Imager"

#: src/Integration/WordPress/Admin/SettingsPage.php:59
msgid "You do not have permission to access this page."
msgstr "У вас нет прав для доступа к этой странице."

#: src/Integration/WordPress/Admin/SettingsPage.php:110
msgid "OXPulse Imager admin failed to load. Try a hard refresh; if it still does not load, check for caching plugins or contact your site administrator."
msgstr "Админка OXPulse Imager не загрузилась. Попробуйте жёсткое обновление (Ctrl+Shift+R); если не поможет — проверьте плагины кэширования или свяжитесь с администратором сайта."

#: src/Integration/WordPress/Admin/StatusRestController.php:136
msgid "No source URL provided."
msgstr "Не передан source URL."

#. translators: %s: PHP version requirement.
#: oxpulse-imager.php:51
msgid "OXPulse Imager requires PHP 8.3 or higher. You are running %s."
msgstr "OXPulse Imager требует PHP 8.3 или выше. У вас установлен %s."

#. translators: %s: WordPress version requirement.
#: oxpulse-imager.php:64
msgid "OXPulse Imager requires WordPress 6.2 or higher. You are running %s."
msgstr "OXPulse Imager требует WordPress 6.2 или выше. У вас установлен %s."

