msgstr "Обнаружены частичные secrets. Установите и key, и salt."

msgid "No secrets configured. Generate a key and salt to enable signed URL delivery."
msgstr "Secrets не настроены. Сгенерируйте key и salt, чтобы включить подписанную доставку URL."

msgid "Delivery"
msgstr "Доставка"

msgid "Enable delivery"
msgstr "Включить доставку"

msgid "Rewrite approved image URLs to signed imgproxy URLs. When disabled, the plugin is a complete no-op on the frontend."
msgstr "Переписывает одобренные URL изображений в подписанные imgproxy URL. Когда отключено — плагин полностью no-op на frontend."

msgid "imgproxy endpoint"
msgstr "endpoint imgproxy"

msgid "Endpoint URL"
msgstr "URL endpoint"

msgid "Base URL of your self-hosted imgproxy instance. HTTPS required in production."
msgstr "Base URL вашего self-hosted imgproxy. HTTPS обязателен в production."

msgid "Signing secrets"
msgstr "Signing secrets"

msgid "Hex-encoded imgproxy key + salt. Minimum 16 bytes after decoding. Never displayed after save — leave empty to keep existing."
msgstr "Hex-кодированные imgproxy key + salt. Минимум 16 байт после декодирования. Никогда не отображаются после сохранения — оставьте пустым, чтобы сохранить существующие."

msgid "Signing key (hex)"
msgstr "Signing key (hex)"

msgid "Leave empty to keep existing"
msgstr "Оставьте пустым, чтобы сохранить существующее"

msgid "Signing salt (hex)"
msgstr "Signing salt (hex)"

msgid "Allowed source origins"
msgstr "Allowed source origins"

msgid "One URL prefix per line. Only images whose URL starts with one of these prefixes will be rewritten. A trailing slash enforces a path boundary."
msgstr "По одному URL-префиксу на строку. Переписываются только изображения, чей URL начинается с одного из этих префиксов. Trailing slash обозначает границу пути."

