msgid "Center"
msgstr "Центр"

#: src/admin/sections/EnhancementsSection.jsx:17
msgid "North"
msgstr "Север"

#: src/admin/sections/EnhancementsSection.jsx:18
msgid "East"
msgstr "Восток"

#: src/admin/sections/EnhancementsSection.jsx:19
msgid "South"
