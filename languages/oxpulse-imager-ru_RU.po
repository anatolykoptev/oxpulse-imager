msgid "North-East"
msgstr "Северо-восток"

#: src/admin/sections/EnhancementsSection.jsx:22
msgid "North-West"
msgstr "Северо-запад"

#: src/admin/sections/EnhancementsSection.jsx:23
msgid "South-East"
msgstr "Юго-восток"

#: src/admin/sections/EnhancementsSection.jsx:24
msgid "South-West"
msgstr "Юго-запад"

#: src/admin/sections/EnhancementsSection.jsx:25
msgid "Replicate (tile)"
msgstr "Реплика (тайл)"

#: src/admin/sections/EnhancementsSection.jsx:26
msgid "Smart"
msgstr "Smart"

#: src/admin/sections/EnhancementsSection.jsx:81
msgid "LQIP placeholders"
msgstr "LQIP-плейсхолдеры"

#: src/admin/sections/EnhancementsSection.jsx:82
msgid "Low-quality image placeholders — tiny blurred previews via imgproxy that reduce Cumulative Layout Shift (CLS). Falls back to inline SVG when imgproxy is unreachable."
msgstr "Low-quality image placeholders — крошечные размытые превью через imgproxy, снижающие Cumulative Layout Shift (CLS). Falls back на inline SVG, если imgproxy недоступен."

#: src/admin/sections/EnhancementsSection.jsx:86
msgid "Emit data-placeholder on img tags"
msgstr "Эмитить data-placeholder на img-тегах"

#: src/admin/sections/EnhancementsSection.jsx:94
msgid "Blur sigma"
msgstr "Сигма размытия"

#: src/admin/sections/EnhancementsSection.jsx:95
msgid "0.1–100. Higher = more blur. 1 is a good default."
msgstr "0.1–100. Больше = сильнее размытие. 1 — хороший default."

#: src/admin/sections/EnhancementsSection.jsx:104
msgid "DPR-aware srcset"
msgstr "DPR-aware srcset"

#: src/admin/sections/EnhancementsSection.jsx:105
msgid "For img tags with width but no srcset, generates 1x/2x/3x x-descriptor variants via imgproxy dpr: option. Images that already have w-descriptor srcset are left alone."
msgstr "Для img-тегов с width, но без srcset, генерирует 1x/2x/3x x-descriptor варианты через опцию imgproxy dpr:. Изображения с w-descriptor srcset не трогаются."

#: src/admin/sections/EnhancementsSection.jsx:109
msgid "Generate DPR variants for images without srcset"
msgstr "Генерировать DPR-варианты для изображений без srcset"

#: src/admin/sections/EnhancementsSection.jsx:116
msgid "DPR multipliers"
msgstr "DPR-множители"

#: src/admin/sections/EnhancementsSection.jsx:117
msgid "Comma-separated, 1–8. e.g. 1,2,3 for standard/retina/hyper-retina."
msgstr "Через запятую, 1–8. напр. 1,2,3 для standard/retina/hyper-retina."

#: src/admin/sections/EnhancementsSection.jsx:126
msgid "Watermark"
msgstr "Watermark"

#: src/admin/sections/EnhancementsSection.jsx:127
msgid "Applies imgproxy native watermark (wm: option). The watermark image is configured server-side via IMGPROXY_WATERMARK_PATH/URL — this setting controls placement only."
msgstr "Применяет нативный watermark imgproxy (опция wm:). Изображение watermark настраивается на сервере через IMGPROXY_WATERMARK_PATH/URL — эта настройка управляет только размещением."

#: src/admin/sections/EnhancementsSection.jsx:131
msgid "Apply watermark"
msgstr "Применить watermark"

#: src/admin/sections/EnhancementsSection.jsx:140
msgid "Opacity"
msgstr "Непрозрачность"

#: src/admin/sections/EnhancementsSection.jsx:141
msgid "0 = transparent, 1 = opaque."
msgstr "0 = прозрачно, 1 = непрозрачно."

#: src/admin/sections/EnhancementsSection.jsx:148
msgid "Position"
msgstr "Позиция"

#: src/admin/sections/EnhancementsSection.jsx:157
msgid "X offset (px)"
msgstr "X-смещение (px)"

#: src/admin/sections/EnhancementsSection.jsx:165
msgid "Y offset (px)"
msgstr "Y-смещение (px)"

#: src/admin/sections/EnhancementsSection.jsx:174
msgid "Scale"
msgstr "Масштаб"

#: src/admin/sections/EnhancementsSection.jsx:175
msgid "0 = auto-size, 0.1 = 10% of source image. Relative to source dimensions."
msgstr "0 = auto-size, 0.1 = 10% исходного изображения. Относительно размеров источника."

#: src/admin/sections/DiagnosticsSection.jsx:41
msgid "Failed to load diagnostics."
msgstr "Не удалось загрузить диагностику."

#: src/admin/sections/DiagnosticsSection.jsx:65
msgid "Failed to clear log."
msgstr "Не удалось очистить лог."

#: src/admin/sections/DiagnosticsSection.jsx:72
msgid "Off (silent)"
msgstr "Off (тихо)"

#: src/admin/sections/DiagnosticsSection.jsx:73
msgid "Basic (per-request counts)"
msgstr "Basic (счётчики на запрос)"

#: src/admin/sections/DiagnosticsSection.jsx:74
msgid "Verbose (per-URL with reason)"
msgstr "Verbose (по URL с причиной)"

#: src/admin/sections/DiagnosticsSection.jsx:80
msgid "Diagnostic level"
msgstr "Уровень диагностики"

#: src/admin/sections/DiagnosticsSection.jsx:81
msgid "Controls what gets written to the PHP error log on each page load. Off = no logging. Basic = one summary line per request (counts by context). Verbose = per-URL entries with reason + redacted source URL."
msgstr "Контролирует, что пишется в PHP error log при каждой загрузке страницы. Off = нет логирования. Basic = одна summary-строка на запрос (счётчики по context). Verbose = по-URL записи с причиной + редуцированным source URL."

#: src/admin/sections/DiagnosticsSection.jsx:85
msgid "Level"
msgstr "Уровень"

#: src/admin/sections/DiagnosticsSection.jsx:91
msgid "Changes take effect on the next page load. The admin bar item (frontend) shows live counts for the current page."
msgstr "Изменения вступят в силу при следующей загрузке страницы. Элемент admin bar (frontend) показывает live-счётчики для текущей страницы."

#: src/admin/sections/DiagnosticsSection.jsx:96
msgid "Recent log entries"
msgstr "Недавние записи лога"

#: src/admin/sections/DiagnosticsSection.jsx:97
msgid "Recent diagnostic entries from the last few requests. Entries are kept for 1 hour. Source URLs are redacted (host + truncated path only)."
