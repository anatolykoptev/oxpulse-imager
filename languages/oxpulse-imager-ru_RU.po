msgid "Endpoint must use HTTPS in production. Enable dev HTTP override only for local development."
msgstr "Endpoint должен использовать HTTPS в production. HTTP разрешён только для локальной разработки через dev-override."

msgid "Endpoint must be HTTP or HTTPS."
msgstr "Endpoint должен быть HTTP или HTTPS."

msgid "Endpoint must be a valid URL or a relative path (e.g. /imgproxy)."
msgstr "Endpoint должен быть валидным URL или относительным путём (напр. /imgproxy)."

msgid "Relative endpoint must start with / and contain only path characters."
msgstr "Относительный endpoint должен начинаться с / и содержать только символы пути."

#. translators: %d: minimum key length in bytes.
msgid "Key must be at least %d bytes after hex decoding."
msgstr "Ключ должен быть не короче %d байт после hex-декодирования."

msgid "Key must be a non-empty even-length hexadecimal string."
msgstr "Ключ должен быть непустой hex-строкой чётной длины."

#. translators: %d: minimum salt length in bytes.
msgid "Salt must be at least %d bytes after hex decoding."
msgstr "Соль должна быть не короче %d байт после hex-декодирования."

msgid "Salt must be a non-empty even-length hexadecimal string."
msgstr "Соль должна быть непустой hex-строкой чётной длины."

msgid "Allowed sources must be valid HTTP(S) URLs with trailing path boundary."
msgstr "Allowed sources должны быть валидными HTTP(S) URL с границей пути в конце."

#. translators: 1: minimum blur, 2: maximum blur.
msgid "LQIP blur must be between %1$s and %2$s."
msgstr "Размытие LQIP должно быть между %1$s и %2$s."

#. translators: 1: minimum, 2: maximum.
msgid "Cache size cap must be between %1$d and %2$d MB."
msgstr ""

msgid "Local base path is not readable by the web server."
msgstr "Local base path не доступен для чтения веб-сервером."

msgid "Local base path does not exist or is not a directory."
msgstr "Local base path не существует или не является директорией."

msgid "Local base path must be an absolute filesystem path (starting with /)."
msgstr "Local base path должен быть абсолютным путём файловой системы (начинаться с /)."

msgid "Local base path is required when source mode is \"local\"."
msgstr "Local base path обязателен, когда source mode = \"local\"."

msgid "Save-Data quality reduction must be between 0 and 50."
msgstr "Снижение качества для Save-Data должно быть от 0 до 50."

msgid "Size quality tier widths must be positive integers."
msgstr "Ширины tier-ов качества должны быть положительными целыми."

msgid "Size quality tier values must be between 1 and 100."
msgstr "Значения tier-ов качества должны быть от 1 до 100."

msgid "Size quality tier per-format values must be between 1 and 100."
msgstr "Значения tier-ов качества по форматам должны быть от 1 до 100."

#. translators: 1: format name, 2: minimum, 3: maximum.
msgid "Quality for %1$s must be between %2$d and %3$d."
msgstr "Качество для %1$s должно быть между %2$d и %3$d."

msgid "Watermark opacity must be between 0 and 1."
msgstr "Непрозрачность watermark должна быть от 0 до 1."

msgid "Invalid watermark position."
msgstr "Невалидная позиция watermark."

msgid "Watermark scale must be between 0 and 1."
msgstr "Масштаб watermark должен быть от 0 до 1."

