{
  "name": "oxpulse-imager-admin",
  "version": "1.0.0",
  "description": "OXPulse Imager — React admin SPA for WordPress",
  "author": "Anatoly Koptev <koptev@koptev.org>",
  "license": "GPL-2.0-or-later",
  "private": true,
  "scripts": {
    "build": "npm run build:admin && npm run write:manifest",
    "build:admin": "vite build --config build/vite.config.js",
    "dev:admin": "vite --config build/vite.config.js",
    "preview:admin": "vite preview --config build/vite.config.js",
    "write:manifest": "node build/write-manifest.mjs",
    "make-pot": "node build/make-pot.mjs",
    "test": "node --test tests/admin/options-store.test.mjs",
    "lint": "eslint 'src/admin/**/*.{js,jsx}'"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.2.11",
    "clsx": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "terser": "^5.19.2",
    "vite": "^4.4.5",
    "wp-pot": "^2.0.0"
  }
}
